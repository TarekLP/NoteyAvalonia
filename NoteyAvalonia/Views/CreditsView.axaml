<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoteToolAvalonia.ViewModels"
             xmlns:local="using:NoteToolAvalonia.Views"
             x:Class="NoteToolAvalonia.Views.CreditsView"
             x:DataType="vm:CreditsViewModel">

    <UserControl.Resources>
        <local:UrlToBitmapConverter x:Key="UrlToBitmapConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.credit-card:pointerover">
            <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
            <Setter Property="RenderTransform" Value="translateX(16px)"/>
            <Setter Property="ZIndex" Value="10"/>
        </Style>

        <Style Selector="Border.credit-card">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.25"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Visible" 
                      HorizontalScrollBarVisibility="Disabled">
            
            <StackPanel Spacing="60" Margin="60,40,80,80">

                <StackPanel Spacing="16">
                    <TextBlock Text="Credits" 
                               FontSize="42" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource Brush.Accent}"/>
                    <TextBlock Text="The people and projects behind Notey" 
                               FontSize="18" 
                               Foreground="{StaticResource Brush.TextSecondary}"/>
                    <Separator Background="{StaticResource Brush.Border}" Height="1" Margin="0,20,0,0"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Credits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,10">
                                
                                <Grid Grid.Column="0" Width="60" RowDefinitions="Auto, *">
                                    <Ellipse Width="16" Height="16" 
                                             Fill="{StaticResource Brush.Accent}" 
                                             Margin="0,42,0,0"
                                             ZIndex="2"/>
                                    <Rectangle Grid.Row="1" Width="2" 
                                               HorizontalAlignment="Center"
                                               Fill="{StaticResource Brush.Border}" 
                                               Margin="0,10,0,0"
                                               MinHeight="100"/>
                                </Grid>

                                <Border Grid.Column="1" 
                                        Classes="credit-card"
                                        Margin="20,0,0,30"
                                        Padding="32"
                                        Background="{StaticResource Brush.Surface}"
                                        BorderBrush="{StaticResource Brush.Border}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Cursor="Hand"
                                        ClipToBounds="False"
                                        PointerPressed="CreditTile_PointerPressed">

                                    <DockPanel LastChildFill="True">
                                        <Border DockPanel.Dock="Left" 
                                                Width="80" 
                                                Height="80" 
                                                CornerRadius="40" 
                                                ClipToBounds="True"
                                                Background="{StaticResource Brush.SurfaceAlt}"
                                                Margin="0,0,32,0">
                                            <Image Source="{Binding IconPath, Converter={StaticResource UrlToBitmapConverter}}"
                                                   Stretch="UniformToFill"/>
                                        </Border>

                                        <TextBlock DockPanel.Dock="Right" 
                                                   Text="VIEW PROJECT ↗" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" 
                                                   Foreground="{StaticResource Brush.Accent}"
                                                   Opacity="0.7"/>

                                        <StackPanel VerticalAlignment="Center" Spacing="8">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="24" 
                                                       FontWeight="Bold" 
                                                       Foreground="{StaticResource Brush.TextPrimary}"/>
                                            <TextBlock Text="{Binding Role}" 
                                                       FontSize="15" 
                                                       Foreground="{StaticResource Brush.TextSecondary}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>