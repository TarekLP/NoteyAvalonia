<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoteToolAvalonia.ViewModels"
             xmlns:md="clr-namespace:Markdown.Avalonia;assembly=Markdown.Avalonia"
             x:Class="NoteToolAvalonia.Views.NoteEditorView"
             x:DataType="vm:NoteEditorViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <!-- Header with Back and Save -->
    <Border Grid.Row="0" Background="{StaticResource Brush.Background}" Padding="15,8" BorderBrush="#252526" BorderThickness="0,0,0,1">
      <DockPanel>
        <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Left">
          <Button Command="{Binding GoBackCommand}" Background="Transparent">
            <TextBlock Text="Back" Foreground="MediumPurple"/>
          </Button>
          <TextBox Text="{Binding NoteTitle}" Width="300" FontWeight="Bold" Background="Transparent" 
                   BorderThickness="0" VerticalAlignment="Center"/>
        </StackPanel>

        <Button DockPanel.Dock="Right" Command="{Binding SaveCommand}" Background="{StaticResource Brush.Accent}" Foreground="White" 
                Content="Save"/>
      </DockPanel>
    </Border>

    <!-- Toolbar -->
    <Border Grid.Row="1" Background="{StaticResource Brush.Background}" Padding="15,8" BorderBrush="#252526" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <!-- Formatting Buttons -->
        <Button ToolTip.Tip="Bold (Ctrl+B)" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="𝐁" FontSize="14" FontWeight="Bold"/>
        </Button>
        <Button ToolTip.Tip="Italic (Ctrl+I)" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="𝘐" FontSize="14" FontStyle="Italic"/>
        </Button>
        <Button ToolTip.Tip="Strikethrough" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="S̶" FontSize="14"/>
        </Button>

        <!-- Separator -->
        <Separator Background="#3e3e42" Margin="4,0"/>

        <!-- Heading Buttons -->
        <Button ToolTip.Tip="Heading 1" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="H1" FontSize="12" FontWeight="Bold"/>
        </Button>
        <Button ToolTip.Tip="Heading 2" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="H2" FontSize="12" FontWeight="Bold"/>
        </Button>
        <Button ToolTip.Tip="Heading 3" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="H3" FontSize="12" FontWeight="Bold"/>
        </Button>

        <!-- Separator -->
        <Separator Background="#3e3e42" Margin="4,0"/>

        <!-- List Buttons -->
        <Button ToolTip.Tip="Bullet List" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="•" FontSize="14"/>
        </Button>
        <Button ToolTip.Tip="Numbered List" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="1." FontSize="12" FontWeight="Bold"/>
        </Button>
        <Button ToolTip.Tip="Checklist" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="☑" FontSize="14"/>
        </Button>

        <!-- Separator -->
        <Separator Background="#3e3e42" Margin="4,0"/>

        <!-- Code and Quote -->
        <Button ToolTip.Tip="Code Block" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="&lt;&gt;" FontSize="12" FontWeight="Bold"/>
        </Button>
        <Button ToolTip.Tip="Quote" Padding="8,4" Background="{StaticResource Brush.Surface}" Foreground="{StaticResource Brush.TextPrimary}">
          <TextBlock Text="&gt;" FontSize="14"/>
        </Button>

        <!-- Spacer -->
        <Border Width="1"/>

        <!-- Preview Toggle -->
        <Button Name="PreviewToggleButton" 
                ToolTip.Tip="Toggle Preview (Ctrl+Shift+P)" 
                Padding="8,4" 
                Background="Transparent" 
                Foreground="{StaticResource Brush.Accent}"
                Margin="0,0,0,0">
          <TextBlock Text="👁️ Preview" FontSize="12"/>
        </Button>
      </StackPanel>
    </Border>

    <!-- Editor and Preview Pane -->
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Editor -->
      <TextBox Grid.Column="0"
               Text="{Binding NoteContent}"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               Background="{StaticResource Brush.Background}"
               BorderThickness="0"
               Padding="30"
               Name="EditorTextBox"/>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" 
                    Width="4" 
                    Background="{StaticResource Brush.Surface}" 
                    Cursor="SizeWestEast"/>

      <!-- Preview Pane -->
      <Border Grid.Column="2" 
              Background="{StaticResource Brush.Background}"
              BorderThickness="1,0,0,0"
              BorderBrush="#252526"
              Padding="30"
              Name="PreviewPane">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <md:MarkdownScrollViewer Markdown="{Binding NoteContent}" />
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Status Bar -->
    <Border Grid.Row="3" Background="{StaticResource Brush.Background}" Padding="20,6" BorderBrush="#252526" BorderThickness="0,1,0,0">
      <StackPanel Orientation="Horizontal" Spacing="20">
        <TextBlock Foreground="#555">
          <Run Text="{Binding WordCount}"/>
          <Run Text=" words"/>
        </TextBlock>
        <TextBlock Foreground="#555">
          <Run Text="{Binding CharacterCount}"/>
          <Run Text=" characters"/>
        </TextBlock>
        <TextBlock Foreground="#555">
          <Run Text="{Binding LineCount}"/>
          <Run Text=" lines"/>
        </TextBlock>
        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Brush.Accent}" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>