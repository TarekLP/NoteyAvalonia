<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoteToolAvalonia.ViewModels"
             x:Class="NoteToolAvalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer>
    <StackPanel Margin="20" Spacing="20">

      <!-- Title -->
      <TextBlock Text="Settings" 
                 FontSize="22" 
                 FontWeight="Bold" 
                 Foreground="{StaticResource Brush.TextPrimary}"/>


      <!-- Font Selection -->
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="Font:" 
                   VerticalAlignment="Center" 
                   Width="120"
                   Foreground="{StaticResource Brush.TextPrimary}"/>
        <ComboBox ItemsSource="{Binding Fonts}" 
                  SelectedItem="{Binding SelectedFont, Mode=TwoWay}" 
                  Width="280"
                  MaxWidth="280"/>
      </StackPanel>

      <!-- Font Size -->
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="Font Size:" 
                   VerticalAlignment="Center" 
                   Width="120"
                   Foreground="{StaticResource Brush.TextPrimary}"/>
        <NumericUpDown Minimum="8" Maximum="32" 
                   Value="{Binding FontSize, Mode=TwoWay}" 
                   Width="120"/>
      </StackPanel>

      <!-- AutoSave -->
      <StackPanel Orientation="Horizontal" Spacing="12">
        <CheckBox Content="Auto Save" 
                  IsChecked="{Binding AutoSave}" 
                  Foreground="{StaticResource Brush.TextPrimary}" 
                  VerticalAlignment="Center"/>
        <TextBlock Text="Interval (min):" 
                   VerticalAlignment="Center" 
                   Foreground="{StaticResource Brush.TextPrimary}"/>
        <NumericUpDown Minimum="1" Maximum="60" 
                Value="{Binding AutoSaveInterval}" 
                Width="120"
                IsReadOnly="False"/>
      </StackPanel>

      <!-- Confirm Delete -->
      <CheckBox Content="Confirm Before Delete" 
                IsChecked="{Binding ConfirmBeforeDelete}" 
                Foreground="{StaticResource Brush.TextPrimary}"/>

      <!-- Show Completed Notes -->
      <CheckBox Content="Show Completed Notes" 
                IsChecked="{Binding ShowCompletedNotes}" 
                Foreground="{StaticResource Brush.TextPrimary}"/>

      <!-- Folder Path (readonly) -->
    <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Data Folder:" 
                    Width="120"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource Brush.TextPrimary}"/>
  
        <TextBox Text="{Binding DataFolderPath}" 
                Width="300" 
                IsReadOnly="True" 
                Foreground="{StaticResource Brush.TextSecondary}"/>
  
        <Button Content="Browse..." 
                Command="{Binding BrowseFolderCommand}" 
                Margin="8,0,0,0"/>
    </StackPanel>

      <!-- Buttons -->
      <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,20,0,0">
        <Button Classes="accent" Command="{Binding SaveSettingsCommand}" MinWidth="80">Save</Button>
        <Button Classes="danger" Command="{Binding ResetDefaultsCommand}" MinWidth="120">Reset Defaults</Button>
        <Button Classes="ghost" Command="{Binding GoBackCommand}" MinWidth="80">Cancel</Button>
      </StackPanel>

      <!-- Status Message -->
      <TextBlock Text="{Binding StatusMessage}" 
                 Foreground="{StaticResource Brush.Accent}" 
                 FontWeight="SemiBold"
                 Margin="0,12,0,0"/>
      
    </StackPanel>
  </ScrollViewer>
</UserControl>