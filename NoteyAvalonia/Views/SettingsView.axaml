<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoteToolAvalonia.ViewModels"
             x:Class="NoteToolAvalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="#0F0F0F">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A1A1A" Padding="25,20" BorderBrush="#2D2D30" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="15">
                <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0">
                    <TextBlock Text="←" FontSize="20" Foreground="#A020F0"/>
                </Button>
                <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="#1A1A1A" Padding="20" BorderBrush="#2D2D30" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#BF40BF" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="Reset Defaults" Command="{Binding ResetDefaultsCommand}" Background="Transparent" Foreground="#888"/>
                    <Button Content="Save Changes" Command="{Binding SaveSettingsCommand}" Background="#A020F0" Foreground="White" Width="150" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Padding="40,20">
            <StackPanel Spacing="30" MaxWidth="800" HorizontalAlignment="Left">
                <StackPanel Spacing="15">
                    <TextBlock Text="APPEARANCE" Foreground="#A020F0" FontSize="12" FontWeight="SemiBold" LetterSpacing="1"/>
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="20">
                            <DockPanel>
                                <TextBlock Text="Theme Mode" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" Width="150" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Separator Background="#2D2D30"/>
                            <DockPanel>
                                <TextBlock Text="Font Family" Foreground="White" VerticalAlignment="Center"/>
                                <ComboBox ItemsSource="{Binding Fonts}" SelectedItem="{Binding SelectedFont}" Width="150" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Separator Background="#2D2D30"/>
                            <DockPanel>
                                <TextBlock Text="Font Size" Foreground="White" VerticalAlignment="Center"/>
                                <NumericUpDown Value="{Binding FontSize}" Minimum="10" Maximum="24" Width="150" HorizontalAlignment="Right"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="15">
                    <TextBlock Text="EDITOR &amp; BEHAVIOR" Foreground="#A020F0" FontSize="12" FontWeight="SemiBold" LetterSpacing="1"/>
                    <Border Background="#1A1A1A" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="15">
                            <ToggleSwitch IsChecked="{Binding AutoSave}" Content="Enable Auto-Save" Foreground="White"/>
                            <DockPanel IsEnabled="{Binding AutoSave}">
                                <TextBlock Text="Auto-Save Interval (minutes)" Foreground="White" VerticalAlignment="Center"/>
                                <NumericUpDown Value="{Binding AutoSaveInterval}" Minimum="1" Maximum="60" Width="150" HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Separator Background="#2D2D30"/>
                            <ToggleSwitch IsChecked="{Binding ConfirmBeforeDelete}" Content="Confirm Before Deletion" Foreground="White"/>
                            <ToggleSwitch IsChecked="{Binding ShowCompletedNotes}" Content="Show Completed Notes" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>