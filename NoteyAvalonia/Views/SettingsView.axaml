<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoteToolAvalonia.ViewModels"
             x:Class="NoteToolAvalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <StackPanel MaxWidth="560" Spacing="40" Margin="40,60">

      <!-- Header -->
      <StackPanel Spacing="10" HorizontalAlignment="Center">
        <TextBlock Text="Settings"
                   FontSize="32" FontWeight="Bold"
                   Foreground="{StaticResource Brush.Accent}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="Customise your Notey experience"
                   FontSize="14"
                   Foreground="{StaticResource Brush.TextSecondary}"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <Separator Background="{StaticResource Brush.Border}" Height="1"/>

      <!-- Appearance -->
      <StackPanel Spacing="20">
        <TextBlock Text="Appearance"
                   FontSize="17" FontWeight="Bold"
                   Foreground="{StaticResource Brush.TextPrimary}"/>
        <StackPanel Spacing="10">
          <TextBlock Text="Theme"
                     FontSize="13"
                     Foreground="{StaticResource Brush.TextSecondary}"/>
          <ComboBox ItemsSource="{Binding Themes}"
                    SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
      </StackPanel>

      <!-- Behaviour -->
      <StackPanel Spacing="20">
        <TextBlock Text="Behaviour"
                   FontSize="17" FontWeight="Bold"
                   Foreground="{StaticResource Brush.TextPrimary}"/>

        <!-- Auto-save -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="Auto-save"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="Automatically save notes as you type"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
          </StackPanel>
          <ToggleSwitch Grid.Column="1"
                        IsChecked="{Binding AutoSave, Mode=TwoWay}"
                        OnContent="" OffContent=""/>
        </Grid>

        <StackPanel Spacing="8" IsVisible="{Binding AutoSave}">
          <TextBlock Text="Save interval (minutes)"
                     FontSize="13"
                     Foreground="{StaticResource Brush.TextSecondary}"/>
          <NumericUpDown Minimum="1" Maximum="60"
                         Value="{Binding AutoSaveInterval, Mode=TwoWay}"/>
        </StackPanel>

        <!-- Confirm before delete -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="Confirm Before Delete"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="Ask before permanently deleting notes"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
          </StackPanel>
          <ToggleSwitch Grid.Column="1"
                        IsChecked="{Binding ConfirmBeforeDelete, Mode=TwoWay}"
                        OnContent="" OffContent=""/>
        </Grid>

        <!-- Show completed -->
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="4">
            <TextBlock Text="Show Completed Notes"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="Include completed notes in the library"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
          </StackPanel>
          <ToggleSwitch Grid.Column="1"
                        IsChecked="{Binding ShowCompletedNotes, Mode=TwoWay}"
                        OnContent="" OffContent=""/>
        </Grid>
      </StackPanel>

      <!-- Actions -->
      <StackPanel Spacing="12" Margin="0,20,0,0">
        <Button Classes="accent"
                Command="{Binding SaveSettingsCommand}"
                HorizontalAlignment="Stretch" Height="44">
          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="✓" VerticalAlignment="Center"/>
            <TextBlock Text="Save and Apply" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Grid ColumnDefinitions="*,*" >
          <Button Grid.Column="0" Content="Reset Defaults"
                  Command="{Binding ResetDefaultsCommand}"
                  Classes="ghost" Margin="0,0,6,0"
                  HorizontalAlignment="Stretch"/>
          <Button Grid.Column="1" Content="← Back"
                  Command="{Binding GoBackCommand}"
                  Classes="ghost" Margin="6,0,0,0"
                  HorizontalAlignment="Stretch"/>
        </Grid>
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{StaticResource Brush.Accent}"
                   HorizontalAlignment="Center"
                   FontSize="12" Margin="0,8,0,0"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
