<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoteToolAvalonia.ViewModels"
             x:Class="NoteToolAvalonia.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer>
    <StackPanel Spacing="0">

      <!-- ═══════════════════════════════════════
           HEADER
           ═══════════════════════════════════════ -->
      <Border Background="{StaticResource Brush.Surface}"
              Padding="40,48,40,40"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="0,0,0,1">
        <StackPanel Spacing="8">
          <TextBlock Text="Settings"
                     FontSize="32" FontWeight="Bold"
                     Foreground="{StaticResource Brush.TextPrimary}"/>
          <TextBlock Text="Customise your Notey experience"
                     FontSize="14"
                     Foreground="{StaticResource Brush.TextSecondary}"/>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════════════════
           SECTIONS
           ═══════════════════════════════════════ -->
      <StackPanel Margin="40,40,40,40" Spacing="48">

        <!-- ── Appearance ── -->
        <StackPanel Spacing="20">
          <StackPanel Spacing="6">
            <TextBlock Text="Appearance"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="Control how Notey looks"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
          </StackPanel>

          <Border Background="{StaticResource Brush.SurfaceAlt}"
                  CornerRadius="12" Padding="24"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Theme"
                         FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource Brush.TextPrimary}"/>
              <ComboBox ItemsSource="{Binding Themes}"
                        SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                        Width="200"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- ── Behaviour ── -->
        <StackPanel Spacing="20">
          <StackPanel Spacing="6">
            <TextBlock Text="Behaviour"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="Adjust how the app saves and handles your notes"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
          </StackPanel>

          <!-- Auto-save card -->
          <Border Background="{StaticResource Brush.SurfaceAlt}"
                  CornerRadius="12" Padding="24"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1">
            <StackPanel Spacing="16">
              <DockPanel>
                <StackPanel DockPanel.Dock="Left" Spacing="4">
                  <TextBlock Text="Auto-save"
                             FontSize="13" FontWeight="SemiBold"
                             Foreground="{StaticResource Brush.TextPrimary}"/>
                  <TextBlock Text="Automatically save notes as you type"
                             FontSize="11"
                             Foreground="{StaticResource Brush.TextSecondary}"/>
                </StackPanel>
                <ToggleSwitch DockPanel.Dock="Right"
                              IsChecked="{Binding AutoSave, Mode=TwoWay}"
                              OnContent="" OffContent=""
                              HorizontalAlignment="Right"/>
              </DockPanel>

              <Border Height="1" Background="{StaticResource Brush.Border}"/>

              <DockPanel IsEnabled="{Binding AutoSave}">
                <TextBlock DockPanel.Dock="Left"
                           Text="Interval:"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           Width="80"/>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal" Spacing="8">
                  <NumericUpDown Minimum="1" Maximum="60"
                                 Value="{Binding AutoSaveInterval, Mode=TwoWay}"
                                 Width="120"/>
                  <TextBlock Text="minutes"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource Brush.TextSecondary}"/>
                </StackPanel>
              </DockPanel>
            </StackPanel>
          </Border>

          <!-- Confirm before delete card -->
          <Border Background="{StaticResource Brush.SurfaceAlt}"
                  CornerRadius="12" Padding="24"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1">
            <DockPanel>
              <StackPanel DockPanel.Dock="Left" Spacing="4">
                <TextBlock Text="Confirm Before Delete"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"/>
                <TextBlock Text="Ask for confirmation before permanently deleting notes"
                           FontSize="11"
                           Foreground="{StaticResource Brush.TextSecondary}"/>
              </StackPanel>
              <ToggleSwitch DockPanel.Dock="Right"
                            IsChecked="{Binding ConfirmBeforeDelete, Mode=TwoWay}"
                            OnContent="" OffContent=""
                            HorizontalAlignment="Right"/>
            </DockPanel>
          </Border>

          <!-- Show completed card -->
          <Border Background="{StaticResource Brush.SurfaceAlt}"
                  CornerRadius="12" Padding="24"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1">
            <DockPanel>
              <StackPanel DockPanel.Dock="Left" Spacing="4">
                <TextBlock Text="Show Completed Notes"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.TextPrimary}"/>
                <TextBlock Text="Include completed notes in your library"
                           FontSize="11"
                           Foreground="{StaticResource Brush.TextSecondary}"/>
              </StackPanel>
              <ToggleSwitch DockPanel.Dock="Right"
                            IsChecked="{Binding ShowCompletedNotes, Mode=TwoWay}"
                            OnContent="" OffContent=""
                            HorizontalAlignment="Right"/>
            </DockPanel>
          </Border>
        </StackPanel>

        <!-- ── Data & Storage ── -->
        <StackPanel Spacing="20">
          <StackPanel Spacing="6">
            <TextBlock Text="Data &amp; Storage"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="Where your notes live on disk"
                       FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
          </StackPanel>

          <Border Background="{StaticResource Brush.SurfaceAlt}"
                  CornerRadius="12" Padding="24"
                  BorderBrush="{StaticResource Brush.Border}"
                  BorderThickness="1">
            <StackPanel Spacing="12">
              <TextBlock Text="Notes Folder"
                         FontSize="13" FontWeight="SemiBold"
                         Foreground="{StaticResource Brush.TextPrimary}"/>
              <TextBlock Text="This is where your .md files are stored. Each note is a portable markdown file you can open in any editor."
                         FontSize="11"
                         Foreground="{StaticResource Brush.TextSecondary}"
                         TextWrapping="Wrap"/>
              <TextBox Text="{Binding DataFolderPath}"
                       IsReadOnly="True"
                       Padding="12,10"
                       CornerRadius="8"
                       Background="{StaticResource Brush.Background}"
                       BorderBrush="{StaticResource Brush.Border}"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       FontSize="12"/>
              <Button Content="Browse Folder"
                      Command="{Binding BrowseFolderCommand}"
                      Classes="ghost"
                      Padding="12,10"
                      HorizontalAlignment="Left"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- ── Actions ── -->
        <StackPanel Spacing="16" Margin="0,16,0,0">
          <Border Height="1" Background="{StaticResource Brush.Border}"/>

          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Classes="accent"
                    Command="{Binding SaveSettingsCommand}"
                    Padding="24,12"
                    FontSize="13" FontWeight="SemiBold">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="✓"/>
                <TextBlock Text="Save Changes"/>
              </StackPanel>
            </Button>

            <Button Classes="ghost"
                    Command="{Binding ResetDefaultsCommand}"
                    Padding="24,12"
                    FontSize="13" FontWeight="SemiBold">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="↺"/>
                <TextBlock Text="Reset to Defaults"/>
              </StackPanel>
            </Button>

            <Button Classes="ghost"
                    Command="{Binding GoBackCommand}"
                    Padding="24,12"
                    FontSize="13" FontWeight="SemiBold">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="←"/>
                <TextBlock Text="Back"/>
              </StackPanel>
            </Button>
          </StackPanel>

          <TextBlock Text="{Binding StatusMessage}"
                     Foreground="{StaticResource Brush.Accent}"
                     FontWeight="SemiBold"
                     FontSize="12"
                     Margin="0,4,0,0"/>
        </StackPanel>

      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
