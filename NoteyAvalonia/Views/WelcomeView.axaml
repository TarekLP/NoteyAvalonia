<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoteToolAvalonia.ViewModels"
             xmlns:converters="using:NoteToolAvalonia.Converters"
             x:Class="NoteToolAvalonia.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel">

  <Grid ColumnDefinitions="260,*">

    <!-- ═══════════════════════════════════════════
         LEFT — Filter panel
         ═══════════════════════════════════════════ -->
    <Border Grid.Column="0"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,0,1,0">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0" Margin="0,20,0,24">

          <!-- New Note button -->
          <Button Command="{Binding ShowCreateNoteCommand}"
                  Classes="accent"
                  Margin="14,0,14,20"
                  HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <TextBlock Text="+" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
              <TextBlock Text="New Note" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Stats -->
          <Border Margin="14,0,14,20"
                  Background="{StaticResource Brush.SurfaceAlt}"
                  CornerRadius="8" Padding="12,10">
            <Grid ColumnDefinitions="*,*,*">
              <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="2">
                <TextBlock Text="{Binding TotalNotes}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource Brush.TextPrimary}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Total" FontSize="10"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           HorizontalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="2">
                <TextBlock Text="{Binding CompletedNotes}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource Brush.Accent}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Done" FontSize="10"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           HorizontalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="2">
                <TextBlock Text="{Binding OverdueNotes}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#ff4757"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Overdue" FontSize="10"
                           Foreground="{StaticResource Brush.TextSecondary}"
                           HorizontalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>

          <Separator Background="{StaticResource Brush.Border}" Margin="14,0,14,18"/>

          <!-- Search -->
          <StackPanel Margin="14,0,14,16" Spacing="6">
            <TextBlock Text="SEARCH" FontSize="10" LetterSpacing="1"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
            <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="Search notes..."
                     CornerRadius="6" Padding="10,8"/>
          </StackPanel>

          <!-- Category -->
          <StackPanel Margin="14,0,14,16" Spacing="6">
            <TextBlock Text="CATEGORY" FontSize="10" LetterSpacing="1"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
            <ComboBox ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" CornerRadius="6"/>
          </StackPanel>

          <!-- Deadline -->
          <StackPanel Margin="14,0,14,16" Spacing="6">
            <TextBlock Text="DEADLINE" FontSize="10" LetterSpacing="1"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
            <ComboBox ItemsSource="{Binding DeadlineFilters}"
                      SelectedItem="{Binding SelectedDeadlineFilter, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" CornerRadius="6"/>
          </StackPanel>

          <!-- Sort -->
          <StackPanel Margin="14,0,14,16" Spacing="6">
            <TextBlock Text="SORT BY" FontSize="10" LetterSpacing="1"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
            <ComboBox ItemsSource="{Binding SortOptions}"
                      SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" CornerRadius="6"/>
          </StackPanel>

          <Separator Background="{StaticResource Brush.Border}" Margin="14,0,14,16"/>

          <!-- Show completed -->
          <Grid ColumnDefinitions="*,Auto" Margin="14,0,14,0">
            <TextBlock Grid.Column="0" Text="Show Completed"
                       FontSize="13" Foreground="{StaticResource Brush.TextPrimary}"
                       VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Column="1"
                          IsChecked="{Binding ShowCompleted, Mode=TwoWay}"
                          OnContent="" OffContent=""/>
          </Grid>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <!-- ═══════════════════════════════════════════
         RIGHT — Note grid
         ═══════════════════════════════════════════ -->
    <ScrollViewer Grid.Column="1" Padding="24">
      <StackPanel Spacing="0">

        <!-- Empty state -->
        <Border IsVisible="{Binding !FilteredNotes.Count}"
                HorizontalAlignment="Center"
                Margin="0,80,0,0">
          <StackPanel Spacing="12" HorizontalAlignment="Center">
            <TextBlock Text="📝" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock Text="No notes found"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Hit New Note to get started, or adjust your filters"
                       FontSize="13"
                       Foreground="{StaticResource Brush.TextSecondary}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Cards -->
        <ItemsControl ItemsSource="{Binding FilteredNotes}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Width="260" Height="180"
                      Margin="0,0,16,16"
                      Background="{StaticResource Brush.Surface}"
                      BorderBrush="{StaticResource Brush.Border}"
                      BorderThickness="1"
                      CornerRadius="12"
                      Cursor="Hand"
                      Tapped="NoteCard_Tapped">
                <Border.Styles>
                  <Style Selector="Border:pointerover">
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                    <Setter Property="Background"   Value="{StaticResource Brush.SurfaceAlt}"/>
                  </Style>
                  <Style Selector="Border">
                    <Setter Property="Transitions">
                      <Transitions>
                        <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                        <BrushTransition Property="Background"  Duration="0:0:0.15"/>
                      </Transitions>
                    </Setter>
                  </Style>
                </Border.Styles>

                <Grid RowDefinitions="Auto,*,Auto" Margin="16,14,16,14">

                  <!-- Category badge + delete -->
                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <Border Grid.Column="0"
                            Background="{StaticResource Brush.Accent}"
                            CornerRadius="4" Padding="6,2"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding Category,
                              Converter={x:Static converters:StringNotEmptyConverter.Instance}}">
                      <TextBlock Text="{Binding Category}"
                                 FontSize="10" FontWeight="SemiBold"
                                 Foreground="White"/>
                    </Border>
                    <Button Grid.Column="1"
                            Command="{Binding $parent[ItemsControl].((vm:WelcomeViewModel)DataContext).DeleteNoteCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent" BorderThickness="0"
                            Padding="4" Cursor="Hand" ToolTip.Tip="Delete note">
                      <TextBlock Text="🗑" FontSize="12"
                                 Foreground="{StaticResource Brush.TextSecondary}"/>
                    </Button>
                  </Grid>

                  <!-- Title + tags -->
                  <StackPanel Grid.Row="1" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.TextPrimary}"
                               TextWrapping="Wrap" MaxLines="2"
                               TextTrimming="CharacterEllipsis"/>
                    <ItemsControl ItemsSource="{Binding Tags}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{StaticResource Brush.SurfaceAlt}"
                                  CornerRadius="4" Padding="5,2" Margin="0,0,4,4">
                            <TextBlock Text="{Binding}" FontSize="10"
                                       Foreground="{StaticResource Brush.TextSecondary}"/>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>

                  <!-- Deadline + date -->
                  <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                    <Border Grid.Column="0"
                            IsVisible="{Binding Deadline,
                              Converter={x:Static converters:DeadlineVisibilityConverter.Instance}}"
                            Background="#33ff4757"
                            CornerRadius="4" Padding="5,2"
                            HorizontalAlignment="Left">
                      <TextBlock Text="{Binding Deadline,
                                   Converter={x:Static converters:DeadlineTextConverter.Instance}}"
                                 FontSize="10" Foreground="#ff4757"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding LastModified, StringFormat='MMM dd'}"
                               FontSize="10"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               VerticalAlignment="Bottom"/>
                  </Grid>

                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ═══════════════════════════════════════════
         NOTE CREATOR OVERLAY
         ═══════════════════════════════════════════ -->
    <Border Grid.Column="0" Grid.ColumnSpan="2"
            IsVisible="{Binding IsCreatingNote}"
            Background="#CC000000">
      <Border Width="480"
              Background="{StaticResource Brush.Surface}"
              CornerRadius="16" Padding="40,36"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              BorderBrush="{StaticResource Brush.Border}" BorderThickness="1">
        <StackPanel Spacing="28">

          <StackPanel Spacing="4">
            <TextBlock Text="New Note" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock FontSize="13" Foreground="{StaticResource Brush.TextSecondary}">
              <Run Text="Step "/>
              <Run Text="{Binding CreatorStep}"/>
              <Run Text=" of 4"/>
            </TextBlock>
          </StackPanel>

          <!-- Step 1: Title -->
          <StackPanel Spacing="8"
                      IsVisible="{Binding CreatorStep,
                        Converter={x:Static converters:IntEqualsConverter.Instance},
                        ConverterParameter=1}">
            <TextBlock Text="What's your note about?"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBox Name="WizardStep1Box"
                     Text="{Binding NewNoteTitle, Mode=TwoWay}"
                     Watermark="Note title..." FontSize="15"
                     Padding="14,12" CornerRadius="8"/>
          </StackPanel>

          <!-- Step 2: Category -->
          <StackPanel Spacing="8"
                      IsVisible="{Binding CreatorStep,
                        Converter={x:Static converters:IntEqualsConverter.Instance},
                        ConverterParameter=2}">
            <TextBlock Text="Which category does it belong to?"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="e.g. Work, Personal, Research..." FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
            <TextBox Name="WizardStep2Box"
                     Text="{Binding NewNoteCategory, Mode=TwoWay}"
                     Watermark="Category (optional)..."
                     Padding="14,12" CornerRadius="8"/>
          </StackPanel>

          <!-- Step 3: Tags -->
          <StackPanel Spacing="8"
                      IsVisible="{Binding CreatorStep,
                        Converter={x:Static converters:IntEqualsConverter.Instance},
                        ConverterParameter=3}">
            <TextBlock Text="Add some tags"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="Comma-separated — e.g. design, ux, prototype" FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
            <TextBox Name="WizardStep3Box"
                     Text="{Binding NewNoteTags, Mode=TwoWay}"
                     Watermark="Tags (optional)..."
                     Padding="14,12" CornerRadius="8"/>
          </StackPanel>

          <!-- Step 4: Deadline -->
          <StackPanel Spacing="8"
                      IsVisible="{Binding CreatorStep,
                        Converter={x:Static converters:IntEqualsConverter.Instance},
                        ConverterParameter=4}">
            <TextBlock Text="Set a deadline?"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"/>
            <TextBlock Text="Enter a date like 2026-07-15, or leave blank to skip" FontSize="12"
                       Foreground="{StaticResource Brush.TextSecondary}"/>
            <TextBox Name="WizardStep4Box"
                     Text="{Binding NewNoteDeadline, Mode=TwoWay}"
                     Watermark="YYYY-MM-DD (optional)..."
                     Padding="14,12" CornerRadius="8"/>
          </StackPanel>

          <!-- Nav buttons -->
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <Button Grid.Column="0" Command="{Binding CancelCreateNoteCommand}"
                    Classes="ghost" Content="Cancel" Padding="16,10"/>
            <Button Grid.Column="2" Command="{Binding CreatorBackCommand}"
                    Classes="ghost" Content="← Back" Padding="16,10"
                    IsVisible="{Binding CreatorStep,
                      Converter={x:Static converters:IntGreaterThanConverter.Instance},
                      ConverterParameter=1}"/>
            <Button Grid.Column="3" Command="{Binding CreatorNextCommand}"
                    Classes="accent" Content="Next →" Padding="16,10" Margin="8,0,0,0"
                    IsVisible="{Binding CreatorStep,
                      Converter={x:Static converters:IntLessThanConverter.Instance},
                      ConverterParameter=4}"/>
            <Button Grid.Column="3" Command="{Binding CreateNoteCommand}"
                    Classes="accent" Content="Create Note" Padding="16,10" Margin="8,0,0,0"
                    IsVisible="{Binding CreatorStep,
                      Converter={x:Static converters:IntEqualsConverter.Instance},
                      ConverterParameter=4}"/>
          </Grid>

        </StackPanel>
      </Border>
    </Border>

  </Grid>
</UserControl>
