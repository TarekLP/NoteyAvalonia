<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NoteToolAvalonia.ViewModels"
             x:Class="NoteToolAvalonia.Views.WelcomeView"
             x:DataType="vm:WelcomeViewModel">

  <ScrollViewer Padding="32,24">
    <StackPanel MaxWidth="900" Spacing="20">

      <StackPanel Margin="0,10,0,20">
        <TextBlock Text="Welcome to Notey" Classes="section-title"/>
        <TextBlock Text="Organize and plan your next Project using this tool!"
                   Classes="subtitle" Margin="0,6,0,0"/>
      </StackPanel>

      <WrapPanel Margin="0,0,0,8">
        <Border Classes="card" MinWidth="150">
          <StackPanel>
            <TextBlock Text="Boards" Classes="subtitle"/>
            <TextBlock Text="{Binding TotalBoards}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Brush.TextPrimary}" />
          </StackPanel>
        </Border>
        <Border Classes="card" MinWidth="150">
          <StackPanel>
            <TextBlock Text="Notes" Classes="subtitle"/>
            <TextBlock Text="{Binding TotalNotes}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Brush.TextPrimary}" />
          </StackPanel>
        </Border>
      </WrapPanel>

      <DockPanel>
        <Button DockPanel.Dock="Right" Classes="accent" Command="{Binding ShowCreateBoardCommand}" Margin="12,0,0,0">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="New Board" VerticalAlignment="Center" MinHeight="40" TextAlignment="Center"/>
          </StackPanel>
        </Button>
        <TextBox Watermark="Search boards..." Text="{Binding SearchText, Mode=TwoWay}"
                 CornerRadius="6" Padding="12,10"/>
      </DockPanel>

      <Border Classes="card" IsVisible="{Binding IsCreatingBoard}">
        <StackPanel Spacing="12">
          <TextBlock Text="Create New Board" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}" />
          <TextBox Watermark="Board name..." Text="{Binding NewBoardName, Mode=TwoWay}" Padding="12,10" CornerRadius="6"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="accent" Command="{Binding CreateBoardCommand}" Content="Create" MinHeight="40"/>
            <Button Classes="ghost" Command="{Binding CancelCreateBoardCommand}" Content="Cancel"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <TextBlock Text="Your Boards" Classes="section-title" Margin="0,8,0,0"/>

      <Border Classes="card" IsVisible="{Binding !FilteredBoards.Count}" HorizontalAlignment="Center" Margin="0,30">
        <StackPanel HorizontalAlignment="Center" Spacing="8">
          <TextBlock Text="No boards yet" FontSize="18" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center"/>
          <TextBlock Text="Click 'New Board' to get started!" FontSize="13" Foreground="{StaticResource Brush.TextSecondary}" HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>

      <ItemsControl ItemsSource="{Binding FilteredBoards}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Classes="card" Margin="0,0,0,4" Cursor="Hand">
              <DockPanel>
                <Button DockPanel.Dock="Right"
                        Classes="ghost"
                        Command="{ReflectionBinding DataContext.DeleteBoardCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"
                        FontSize="16"
                        ToolTip.Tip="Delete board"
                        Content="🗑">
                  <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                      <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                    </Style>
                  </Button.Styles>
                </Button>

                <Border Background="Transparent" Cursor="Hand" Tapped="BoardCard_Tapped">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Name}" 
                               FontSize="18" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource Brush.TextPrimary}"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                      <TextBlock Text="{Binding Columns.Count, StringFormat='{}{0} columns'}" 
                                 Foreground="{StaticResource Brush.TextSecondary}" 
                                 FontSize="12"/>
                      <TextBlock Text="{Binding LastModified, StringFormat='{}{0:MMM dd, yyyy}'}" 
                                 Foreground="{StaticResource Brush.TextSecondary}" 
                                 FontSize="12"/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DockPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

    </StackPanel>
  </ScrollViewer>
</UserControl>